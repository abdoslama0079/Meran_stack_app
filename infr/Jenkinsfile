properties([
    parameters([
        string(name: 'Environment', defaultValue: 'dev', description: 'Environment name (dev, staging, prod)'),
        choice(name: 'Terraform_Action', choices: ['plan', 'apply', 'destroy'], description: 'Select the Terraform action to perform')
    ])
])

pipeline {
    agent any

    environment {
        // Points to the directory where your AKS Terraform modules live
        TF_DIR = "/modules/AKS"
    }

    stages {
        stage('Preparing & Clean') {
            steps {
                sh 'echo "Starting Pipeline for ${params.Environment}..."'
                deleteDir() // Clean workspace for a fresh start
            }
        }

        stage('Git Pulling') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([azureServicePrincipal('meran_stack_sp')]) {
                    sh "terraform -chdir=${env.TF_DIR} init"
                }
            }
        }

        stage('Quality & Security Gates') {
            parallel {
                stage('Format Check') {
                    steps {
                        sh "terraform -chdir=${env.TF_DIR} fmt -check"
                    }
                }
                stage('Validate Syntax') {
                    steps {
                        sh "terraform -chdir=${env.TF_DIR} validate"
                    }
                }
                stage('tfsec Scan') {
                    steps {
                        // This identifies security risks in your AKS configuration
                        sh "tfsec ${env.TF_DIR}"
                    }
                }
            }
        }

        stage('Terraform Action') {
            steps {
                withCredentials([azureServicePrincipal('meran_stack_sp')]) {
                    script {
                        def varFile = "${params.Environment}.tfvars"

                        if (params.Terraform_Action == 'plan') {
                            sh "terraform -chdir=${env.TF_DIR} plan -var-file=${varFile}"
                        }
                        else if (params.Terraform_Action == 'apply') {
                            sh "terraform -chdir=${env.TF_DIR} apply -var-file=${varFile} -auto-approve"
                        }
                        else if (params.Terraform_Action == 'destroy') {
                            sh "terraform -chdir=${env.TF_DIR} destroy -var-file=${varFile} -auto-approve"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'echo "Pipeline execution finished."'
        }
        failure {
            sh 'echo "Pipeline FAILED. Check the security scan or terraform logs."'
        }
    }
}