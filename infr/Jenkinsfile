properties([
    parameters([
        string(
            name: 'Environment',
            defaultValue: 'dev',
            description: 'Environment name (dev, staging, prod)'
        ),
        choice(
            name: 'Terraform_Action',
            choices: ['plan', 'apply', 'destroy'],
            description: 'Select the Terraform action to perform'
        )
    ])
])

pipeline {
    agent any

    environment {
        TF_DIR = "infr/"
    }

    stages {

        stage('Preparing & Clean') {
            steps {
                sh "echo Starting Pipeline for ${params.Environment}..."
                deleteDir()
            }
        }

        stage('Git Pulling') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([azureServicePrincipal('meran_stack_sp')]) {
                    sh "terraform -chdir=${env.TF_DIR} init"
                }
            }
        }

        stage('Quality Gates') {
            parallel {

                stage('Format Check') {
                    steps {
                        sh "terraform -chdir=${env.TF_DIR} fmt"
                    }
                }

                stage('Validate Syntax') {
                    steps {
                        sh "terraform -chdir=${env.TF_DIR} validate"
                    }
                }

            }
        }

        stage('Terraform Plan') {
            when {
                expression { params.Terraform_Action == 'plan' || params.Terraform_Action == 'apply' }
            }
            steps {
                withCredentials([
                    azureServicePrincipal(
                        credentialsId: 'meran_stack_sp',
                        clientIdVariable: 'ARM_CLIENT_ID',
                        clientSecretVariable: 'ARM_CLIENT_SECRET',
                        subscriptionIdVariable: 'ARM_SUBSCRIPTION_ID',
                        tenantIdVariable: 'ARM_TENANT_ID'
                    )
                ]) {
                    sh "terraform -chdir=${env.TF_DIR} plan -out=tfplan"
                }
            }
        }

        stage('Approval Before Apply') {
            when {
                expression { params.Terraform_Action == 'apply' }
            }
            steps {
                input message: "Approve Terraform Apply to ${params.Environment}?"
            }
        }

        stage('Terraform Apply') {
            when {
                expression { params.Terraform_Action == 'apply' }
            }
            steps {
                withCredentials([
                    azureServicePrincipal(
                        credentialsId: 'meran_stack_sp',
                        clientIdVariable: 'ARM_CLIENT_ID',
                        clientSecretVariable: 'ARM_CLIENT_SECRET',
                        subscriptionIdVariable: 'ARM_SUBSCRIPTION_ID',
                        tenantIdVariable: 'ARM_TENANT_ID'
                    )
                ]) {
                    sh "terraform -chdir=${env.TF_DIR} apply tfplan"
                }
            }
        }

        stage('Terraform Destroy') {
            when {
                expression { params.Terraform_Action == 'destroy' }
            }
            steps {
                withCredentials([
                    azureServicePrincipal(
                        credentialsId: 'meran_stack_sp',
                        clientIdVariable: 'ARM_CLIENT_ID',
                        clientSecretVariable: 'ARM_CLIENT_SECRET',
                        subscriptionIdVariable: 'ARM_SUBSCRIPTION_ID',
                        tenantIdVariable: 'ARM_TENANT_ID'
                    )
                ]) {
                    sh "terraform -chdir=${env.TF_DIR} destroy -auto-approve"
                }
            }
        }

        stage('Terraform Outputs') {
            steps {
                script {
                                        withCredentials([
                    azureServicePrincipal(
                        credentialsId: 'meran_stack_sp',
                        clientIdVariable: 'ARM_CLIENT_ID',
                        clientSecretVariable: 'ARM_CLIENT_SECRET',
                        subscriptionIdVariable: 'ARM_SUBSCRIPTION_ID',
                        tenantIdVariable: 'ARM_TENANT_ID'
                    )
                ]) {
                def acr_login_server = sh(
                                script: "terraform -chdir=${env.TF_DIR} output -raw acr_login_server",
                                returnStdout: true
                            ).trim()

                            def kvUri = sh(
                                script: "terraform -chdir=${env.TF_DIR} output -raw key_vault_uri",
                                returnStdout: true
                            ).trim()

                            def clientId = sh(
                                script: "terraform -chdir=${env.TF_DIR} output -raw workload_identity_client_id",
                                returnStdout: true
                            ).trim()

                            def storageName = sh(
                                script: "terraform -chdir=${env.TF_DIR} output -raw aks_storage_account_name",
                                returnStdout: true
                            ).trim()

                            echo "--- INFRASTRUCTURE COORDINATES ---"
                            echo "ACR Login Server: ${acr_login_server}"
                            echo "Key Vault URI: ${kvUri}"
                            echo "Azure Client ID (Workload Identity): ${clientId}"
                            echo "Storage Account: ${storageName}"
                            echo "----------------------------------"
                }
                }
            }
        }

    }

    post {
        always {
            sh "echo Pipeline execution finished."
        }

        failure {
            sh "echo Pipeline FAILED. Check the logs."
        }
    }
}